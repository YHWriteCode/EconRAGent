# ===== 基础连接配置 =====
REDIS_URI=redis://127.0.0.1:6379
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# Qdrant（推荐提供 QDRANT_URL；也可用 HOST/PORT）
QDRANT_URL=http://127.0.0.1:6333
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# Mongo（脚本支持 MONGODB_URI -> MONGO_URI 自动映射）
MONGODB_URI=mongodb://127.0.0.1:27017
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=lightrag

# ===== LLM(OpenAI-compatible) =====
LLM_BINDING_HOST=http://127.0.0.1:8000/v1
LLM_BINDING_API_KEY=your_api_key

# 脚本会自动映射：
# OPENAI_API_BASE <- LLM_BINDING_HOST
# OPENAI_API_KEY  <- LLM_BINDING_API_KEY
OPENAI_API_BASE=http://127.0.0.1:8000/v1
OPENAI_API_KEY=your_api_key
LLM_MODEL_NAME=qwen-plus

EMBEDDING_TIMEOUT=180
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=qwen3-embed-0_6b:latest
EMBEDDING_DIM=1024
EMBEDDING_BINDING_API_KEY=your_api_key
EMBEDDING_BINDING_HOST=http://host.docker.internal:11434
EMBEDDING_MODEL=text-embedding-3-small

# ===== 锁相关（可选，留空用默认） =====
LIGHTRAG_LOCK_KEY_PREFIX=lightrag:lock
LIGHTRAG_LOCK_RENEW_INTERVAL_S=
LIGHTRAG_LOCK_MAX_RETRIES=
LIGHTRAG_PIPELINE_RUNTIME_LOCK_TTL_S=120
LIGHTRAG_PIPELINE_ENQUEUE_LOCK_TTL_S=60
