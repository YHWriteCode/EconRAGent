######################################################################
# LightRAG 主 LLM 与 OpenAI 兼容回退配置
######################################################################
# LightRAG 主模型绑定类型；当前使用 openai 兼容接口接 DeepSeek。
LLM_BINDING=openai
# LightRAG 主模型名称。
LLM_MODEL=deepseek-chat
# LightRAG 主模型 API Base URL。
LLM_BINDING_HOST=https://api.deepseek.com/v1
# LightRAG 主模型 API Key。
LLM_BINDING_API_KEY=
# OpenAI 兼容回退模型名；留空时由 LLM_MODEL 提供。
OPENAI_MODEL=
# OpenAI 兼容回退 Base URL；留空时由 LLM_BINDING_HOST 提供。
OPENAI_BASE_URL=
# OpenAI 兼容回退 API Key；留空时由 LLM_BINDING_API_KEY 提供。
OPENAI_API_KEY=

######################################################################
# LightRAG Utility Summary LLM 配置
######################################################################
# LightRAG 内部摘要任务使用的绑定类型；未单独配置模型时不会启用。
UTILITY_LLM_BINDING=openai
# kg_agent 可识别的 utility provider 标识。
UTILITY_LLM_PROVIDER=openai_compatible
# 轻量 utility 模型名称；留空时回退主模型。
UTILITY_LLM_MODEL=
# 轻量 utility 模型 API Base URL；留空时回退主模型。
UTILITY_LLM_BINDING_HOST=
# 轻量 utility 模型 API Key；留空时回退主模型。
UTILITY_LLM_BINDING_API_KEY=
# 轻量 utility 模型超时秒数。
UTILITY_LLM_TIMEOUT=60.0

######################################################################
# Embedding 配置
######################################################################
# Embedding 提供方；当前使用本机 Ollama。
EMBEDDING_BINDING=ollama
# Embedding 模型名称。
EMBEDDING_MODEL=qwen3-embedding:8b
# Embedding 向量维度。
EMBEDDING_DIM=4096
# Embedding API Base URL。
EMBEDDING_BINDING_HOST=http://127.0.0.1:11434/v1
# Embedding API Key；本地 Ollama 可留空。
EMBEDDING_BINDING_API_KEY=
# Embedding 请求超时秒数。
EMBEDDING_TIMEOUT=180

######################################################################
# Rerank 配置
######################################################################
# Rerank 绑定；使用 null 表示关闭。
RERANK_BINDING=null
# Rerank 模型名称；启用 rerank 时再填写。
RERANK_MODEL=
# Rerank API Base URL；启用 rerank 时再填写。
RERANK_BINDING_HOST=
# Rerank API Key；启用 rerank 时再填写。
RERANK_BINDING_API_KEY=
# Rerank 最低保留分数阈值。
MIN_RERANK_SCORE=0.0
# 是否启用长文 chunked rerank。
RERANK_ENABLE_CHUNKING=false
# 单文档最大 rerank token 数。
RERANK_MAX_TOKENS_PER_DOC=4096

######################################################################
# LightRAG 存储后端选择
######################################################################
# KV 存储后端。
LIGHTRAG_KV_STORAGE=RedisKVStorage
# 文档状态存储后端。
LIGHTRAG_DOC_STATUS_STORAGE=MongoDocStatusStorage
# 向量存储后端。
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage
# 图存储后端。
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage

######################################################################
# LightRAG 分布式锁与流水线锁配置
######################################################################
# 锁后端；单机默认 local，多实例可改为 redis。
LIGHTRAG_LOCK_BACKEND=local
# Redis 锁失败时的处理模式。
LIGHTRAG_LOCK_FAIL_MODE=strict
# Redis 锁键前缀。
LIGHTRAG_LOCK_KEY_PREFIX=lightrag:lock
# 锁续租间隔秒数；None 表示自动按 TTL 推导。
LIGHTRAG_LOCK_RENEW_INTERVAL_S=None
# pipeline runtime 锁等待超时秒数；0 表示不等待。
LIGHTRAG_PIPELINE_RUNTIME_LOCK_WAIT_TIMEOUT_S=0
# pipeline enqueue 锁等待超时秒数；None 表示无限或由实现决定。
LIGHTRAG_PIPELINE_ENQUEUE_LOCK_WAIT_TIMEOUT_S=None

######################################################################
# Neo4j 配置
######################################################################
# Neo4j 连接 URI。
NEO4J_URI=neo4j://127.0.0.1:7687
# Neo4j 用户名。
NEO4J_USERNAME=neo4j
# Neo4j 密码。
NEO4J_PASSWORD=password123
# Neo4j 物理数据库名；Community Edition 建议保持 neo4j。
NEO4J_DATABASE=neo4j
# Neo4j 连接池大小。
NEO4J_MAX_CONNECTION_POOL_SIZE=100
# Neo4j 连接超时秒数。
NEO4J_CONNECTION_TIMEOUT=30
# Neo4j 连接获取超时秒数。
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=30
# Neo4j 事务重试最大时长秒数。
NEO4J_MAX_TRANSACTION_RETRY_TIME=30
# Neo4j 连接最大生命周期秒数。
NEO4J_MAX_CONNECTION_LIFETIME=300
# Neo4j 存活检查超时秒数。
NEO4J_LIVENESS_CHECK_TIMEOUT=30
# 是否启用 Neo4j keep-alive。
NEO4J_KEEP_ALIVE=true

######################################################################
# Qdrant 配置
######################################################################
# Qdrant 服务地址。
QDRANT_URL=http://127.0.0.1:6333
# Qdrant API Key；本地未鉴权可留空。
QDRANT_API_KEY=
# 强制指定 Qdrant workspace 名称；留空时按 LightRAG namespace 生成。
QDRANT_WORKSPACE=

######################################################################
# Redis 配置
######################################################################
# Redis 连接 URI。
REDIS_URI=redis://127.0.0.1:6379
# Redis socket 超时秒数。
REDIS_SOCKET_TIMEOUT=30
# Redis 建连超时秒数。
REDIS_CONNECT_TIMEOUT=10
# Redis 最大连接数。
REDIS_MAX_CONNECTIONS=100
# Redis 操作重试次数。
REDIS_RETRY_ATTEMPTS=3

######################################################################
# MongoDB 配置
######################################################################
# MongoDB 连接 URI 的兼容别名；部分脚本会先看这个变量。
MONGODB_URI=mongodb://admin:password123@localhost:27017/?authSource=admin
# MongoDB 主连接 URI。
MONGO_URI=mongodb://admin:password123@localhost:27017/?authSource=admin
# MongoDB 默认数据库名。
MONGO_DATABASE=lightrag_test
# Mongo 初始化 root 用户名。
MONGO_INITDB_ROOT_USERNAME=admin
# Mongo 初始化 root 密码。
MONGO_INITDB_ROOT_PASSWORD=password123

######################################################################
# kg_agent 主模型配置
######################################################################
# Agent 主模型 provider 标识。
KG_AGENT_MODEL_PROVIDER=openai_compatible
# Agent 主模型名称；留空时回退 LLM_MODEL / OPENAI_MODEL。
KG_AGENT_MODEL_NAME=
# Agent 主模型 Base URL；留空时回退 OPENAI_BASE_URL / LLM_BINDING_HOST。
KG_AGENT_MODEL_BASE_URL=
# Agent 主模型 API Key；留空时回退 OPENAI_API_KEY / LLM_BINDING_API_KEY。
KG_AGENT_MODEL_API_KEY=
# Agent 主模型超时秒数。
KG_AGENT_MODEL_TIMEOUT_S=60.0

######################################################################
# kg_agent Utility 模型配置
######################################################################
# Agent utility 模型 provider 标识。
KG_AGENT_UTILITY_MODEL_PROVIDER=openai_compatible
# Agent utility 模型名称；留空时回退 UTILITY_LLM_MODEL 或主模型。
KG_AGENT_UTILITY_MODEL_NAME=
# Agent utility 模型 Base URL；留空时回退 UTILITY_LLM_BINDING_HOST 或主模型。
KG_AGENT_UTILITY_MODEL_BASE_URL=
# Agent utility 模型 API Key；留空时回退 UTILITY_LLM_BINDING_API_KEY 或主模型。
KG_AGENT_UTILITY_MODEL_API_KEY=
# Agent utility 模型超时秒数。
KG_AGENT_UTILITY_MODEL_TIMEOUT_S=60.0

######################################################################
# kg_agent 工具开关
######################################################################
# 是否启用 web_search 工具。
KG_AGENT_ENABLE_WEB_SEARCH=false
# 是否启用会话记忆工具。
KG_AGENT_ENABLE_MEMORY=true
# 是否启用 quant 工具占位实现。
KG_AGENT_ENABLE_QUANT=true
# 是否启用 kg_ingest 工具。
KG_AGENT_ENABLE_KG_INGEST=true

######################################################################
# kg_agent 运行时与 API 配置
######################################################################
# LightRAG 默认 workspace；kg_agent 未显式传入时会回退到这里。
WORKSPACE=kg_agent_demo
# kg_agent 默认 workspace。
KG_AGENT_DEFAULT_WORKSPACE=kg_agent_demo
# kg_agent 默认领域 schema。
KG_AGENT_DEFAULT_DOMAIN_SCHEMA=economy
# kg_agent/LightRAG 实体关系抽取与摘要输出语言；内部 schema 名仍使用英文 canonical name。
SUMMARY_LANGUAGE=Chinese
# Agent 单轮最大工具调用轮数。
KG_AGENT_MAX_ITERATIONS=3
# Route Judge LLM refinement prompt 版本。
KG_AGENT_ROUTE_JUDGE_PROMPT_VERSION=v1
# 动态记忆窗口最多考虑的历史轮数。
KG_AGENT_MEMORY_WINDOW_TURNS=6
# 动态记忆窗口最少保留的最近轮数。
KG_AGENT_MEMORY_MIN_RECENT_TURNS=2
# 路由与回答阶段的软 token 预算。
KG_AGENT_MEMORY_MAX_CONTEXT_TOKENS=1200
# 是否启用 kg_agent 调试模式。
KG_AGENT_DEBUG=false
# kg_agent API 监听地址。
KG_AGENT_HOST=0.0.0.0
# kg_agent API 监听端口。
KG_AGENT_PORT=9721

######################################################################
# kg_agent Web Crawler 基础配置
######################################################################
# 当前爬虫后端。
KG_AGENT_WEB_CRAWLER_PROVIDER=crawl4ai
# Crawl4AI 浏览器类型。
KG_AGENT_WEB_CRAWLER_BROWSER_TYPE=chromium
# 优先复用的系统浏览器通道；可选 chrome 或 msedge。
KG_AGENT_WEB_CRAWLER_BROWSER_CHANNEL=
# 是否无头运行浏览器。
KG_AGENT_WEB_CRAWLER_HEADLESS=true
# 是否输出 Crawl4AI 详细日志。
KG_AGENT_WEB_CRAWLER_VERBOSE=false
# Crawl4AI 缓存模式。
KG_AGENT_WEB_CRAWLER_CACHE_MODE=BYPASS
# 单次 crawl 最多抓取的页面数。
KG_AGENT_WEB_CRAWLER_MAX_PAGES=3
# 单页下游保留的最大内容字符数。
KG_AGENT_WEB_CRAWLER_MAX_CONTENT_CHARS=4000
# 单页最小有效词数阈值。
KG_AGENT_WEB_CRAWLER_WORD_COUNT_THRESHOLD=20
# 单页抓取超时毫秒数。
KG_AGENT_WEB_CRAWLER_PAGE_TIMEOUT_MS=30000

######################################################################
# kg_agent Web Crawler LLM Extraction 配置
######################################################################
# 是否启用 Crawl4AI 的 LLMExtractionStrategy。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_ENABLED=false
# Crawl4AI LLM extraction provider；留空时自动推导为 openai/<model>。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_PROVIDER=
# Crawl4AI LLM extraction API Token；留空时回退主 LLM Key。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_API_TOKEN=
# Crawl4AI LLM extraction Base URL；留空时回退主 LLM Host。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_BASE_URL=
# Crawl4AI LLM extraction 指令；留空时使用默认策略。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_INSTRUCTION=
# Crawl4AI LLM extraction 输入格式。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_INPUT_FORMAT=markdown
# Crawl4AI LLM extraction 类型；可选 block 或 schema。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_TYPE=block
# schema 模式下的 JSON Schema 字符串。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_SCHEMA_JSON=
# 是否强制 extraction LLM 输出 JSON。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_FORCE_JSON_RESPONSE=false
# 是否允许 Crawl4AI 在 extraction 前自动分块。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_APPLY_CHUNKING=true
# 是否优先用 extracted_content 替换原始 markdown 进入下游。
KG_AGENT_WEB_CRAWLER_LLM_EXTRACTION_PREFER_CONTENT=false

######################################################################
# kg_agent 调度器配置
######################################################################
# 是否启用定时抓取调度器。
KG_AGENT_ENABLE_SCHEDULER=false
# 调度器轮询间隔秒数。
KG_AGENT_SCHEDULER_CHECK_INTERVAL=60
# SourceRegistry 的 JSON 持久化文件；留空表示仅内存。
KG_AGENT_SCHEDULER_SOURCES_FILE=
# CrawlStateStore 的 JSON 状态文件路径。
KG_AGENT_SCHEDULER_STATE_FILE=scheduler_state.json
# 是否启用调度器 leader election。
KG_AGENT_SCHEDULER_ENABLE_LEADER_ELECTION=false
# 调度器循环租约 key。
KG_AGENT_SCHEDULER_LOOP_LEASE_KEY=scheduler:loop
# 调度器协调后端；可选 auto、local、redis。
KG_AGENT_SCHEDULER_COORDINATION_BACKEND=auto
# 调度器协调使用的 Redis URL；留空时可复用 REDIS_URI。
KG_AGENT_SCHEDULER_COORDINATION_REDIS_URL=
# 调度器租约 TTL 秒数。
KG_AGENT_SCHEDULER_COORDINATION_TTL_SECONDS=120

######################################################################
# kg_agent Memory / Profile / Scheduler Store / Cross-session 配置
######################################################################
# 会话记忆后端；可选 memory、sqlite、mongo。
KG_AGENT_MEMORY_BACKEND=memory
# 会话记忆 SQLite 文件路径。
KG_AGENT_MEMORY_SQLITE_PATH=kg_agent_memory.sqlite3
# 会话记忆 Mongo 集合名。
KG_AGENT_MEMORY_MONGO_COLLECTION=kg_agent_conversation_messages
# 用户画像后端；可选 memory、sqlite、mongo。
KG_AGENT_USER_PROFILE_BACKEND=memory
# 用户画像 SQLite 文件路径。
KG_AGENT_USER_PROFILE_SQLITE_PATH=kg_agent_profiles.sqlite3
# 用户画像 Mongo 集合名。
KG_AGENT_USER_PROFILE_MONGO_COLLECTION=kg_agent_user_profiles
# 调度器 source/state 存储后端；可选 json 或 sqlite。
KG_AGENT_SCHEDULER_STORE_BACKEND=json
# 调度器 SQLite 文件路径。
KG_AGENT_SCHEDULER_STORE_SQLITE_PATH=kg_agent_scheduler.sqlite3
# 跨会话记忆后端；可选 memory、auto、mongo_qdrant。
KG_AGENT_CROSS_SESSION_BACKEND=memory
# 跨会话记忆 Mongo 集合名。
KG_AGENT_CROSS_SESSION_MONGO_COLLECTION=kg_agent_cross_session_messages
# 跨会话记忆 Qdrant collection 前缀。
KG_AGENT_CROSS_SESSION_QDRANT_COLLECTION_PREFIX=kg_agent_cross_session
# 进入跨会话向量索引的最小内容长度。
KG_AGENT_CROSS_SESSION_MIN_CONTENT_CHARS=8
# 进入跨会话向量索引的最大内容长度。
KG_AGENT_CROSS_SESSION_MAX_CONTENT_CHARS=1200
# 单条跨会话记忆最多保留的 session 引用数。
KG_AGENT_CROSS_SESSION_MAX_SESSION_REFS=12
# 是否启用跨会话记忆语义合并。
KG_AGENT_CROSS_SESSION_ENABLE_CONSOLIDATION=true
# 跨会话记忆合并的最小相似度阈值。
KG_AGENT_CROSS_SESSION_CONSOLIDATION_SIMILARITY_THRESHOLD=0.82
# 合并时检查的最近邻候选数量。
KG_AGENT_CROSS_SESSION_CONSOLIDATION_TOP_K=3
# 聚合记忆最多保留的 snippet 数。
KG_AGENT_CROSS_SESSION_MAX_CLUSTER_SNIPPETS=6
# 是否启用跨会话后台维护任务。
KG_AGENT_CROSS_SESSION_ENABLE_BACKGROUND_MAINTENANCE=false
# 后台维护轮询间隔秒数。
KG_AGENT_CROSS_SESSION_MAINTENANCE_INTERVAL_SECONDS=1800
# 单次后台维护最多处理的记忆条数。
KG_AGENT_CROSS_SESSION_MAINTENANCE_BATCH_SIZE=100
# 记忆进入 stale 压缩的天数阈值。
KG_AGENT_CROSS_SESSION_AGING_STALE_AFTER_DAYS=14.0
# 低支持度旧记忆允许删除的天数阈值。
KG_AGENT_CROSS_SESSION_AGING_DELETE_AFTER_DAYS=60.0
# 保护旧记忆不被删除的最小出现次数。
KG_AGENT_CROSS_SESSION_AGING_KEEP_MIN_OCCURRENCES=2
# aged summary 最多保留的 snippet 数。
KG_AGENT_CROSS_SESSION_AGING_MAX_SNIPPETS=3

######################################################################
# kg_agent Freshness 与自动入库配置
######################################################################
# KG 结果被认为过旧的秒数阈值。
KG_AGENT_FRESHNESS_THRESHOLD_SECONDS=604800
# 是否允许 chat 期间触发自动入库桥接。
KG_AGENT_ENABLE_AUTO_INGEST=false
# Freshness decay 半衰期天数。
KG_AGENT_STALENESS_DECAY_DAYS=7.0
# 是否启用 freshness-aware retrieval decay。
KG_AGENT_ENABLE_FRESHNESS_DECAY=false

# Minimal dockerized skill-runtime example.
# Replace D:/skill-runtime with a real host path that Docker Desktop can mount.

KG_AGENT_MCP_SERVERS_JSON=[{"name":"skill-runtime","command":"docker","stdio_framing":"json_lines","args":["run","--rm","-i","-e","MCP_SKILLS_DIR=/app/skills","-e","MCP_WORKSPACE_DIR=/workspace","-e","MCP_SCRIPT_TIMEOUT_S=900","-e","MCP_RUN_TIMEOUT_S=1200","-v","D:/skill-runtime:/workspace","econragent-mcp-skill-service:latest","python","/app/server.py"],"startup_timeout_s":20.0,"tool_timeout_s":1200.0,"discover_tools":false}]
KG_AGENT_SKILL_RUNTIME_SERVER=skill-runtime
KG_AGENT_SKILL_RUNTIME_ARTIFACTS_TOOL=host_workspace_fallback
KG_AGENT_SKILL_TARGET_NETWORK_ALLOWED=true
